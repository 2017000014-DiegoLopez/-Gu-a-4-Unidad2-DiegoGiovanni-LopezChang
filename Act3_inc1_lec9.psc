Algoritmo Act3_inc1_lec9
	Definir n, num Como Entero
    Escribir "Ingresa un número mayor a 20:"
    Leer n
    Mientras n <= 20 Hacer
        Escribir "El número debe ser mayor a 20, intentar de nuevo:"
        Leer n
    FinMientras
    num <- 21
    Mientras num < N Hacer
        Escribir num
        num <- num + 2
    FinMientras
FinAlgoritmo
